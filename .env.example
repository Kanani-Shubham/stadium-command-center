# ── StadiumSense AI — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Groq API key for AI features (https://console.groq.com)
GROQ_API_KEY=gsk_your_primary_key_here

# Optional: Second Groq API key for key rotation / higher rate limits
GROQ_API_KEY_2=gsk_your_secondary_key_here

# Required: Express session secret — use a strong random string in production
# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_64_char_string

# Set automatically by Replit — do not set manually
# PORT=8080
# DATABASE_URL=postgresql://...
# REPLIT_DEV_DOMAIN=your-repl.replit.dev
